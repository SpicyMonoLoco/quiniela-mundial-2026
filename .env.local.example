# Copia este archivo a .env.local y completa los valores
# Estos valores los vas a obtener al crear tu proyecto en Supabase (Settings -> API)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# football-data.org - regístrate gratis en https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=tu_api_key_aqui

# Secret para proteger el cron de actualización de resultados (inventa una cadena larga)
CRON_SECRET=cambia_esto_por_algo_largo_y_aleatorio

# Email del admin (debe coincidir con el email con el que te logueas)
ADMIN_EMAIL=daniel.zamora@thoropass.com

# Nombre público de la quiniela
NEXT_PUBLIC_POOL_NAME=Quiniela PDP Mundial 2026
